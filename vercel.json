{
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "Link",
          "value": "</logo-b.png>; rel=preload; as=image"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://fycs-study-hub.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ]
}
