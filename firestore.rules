rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🛡️ Helper Function: Safe Role Check (Avoids crashes for first-time visitors)
    function getUserRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.role : 'student';
    }

    // 📚 1. MATERIALS RULES
    match /materials/{document} {
      allow read: if true; 
      
      // ✅ Normal users can upload, but the status must be 'Pending'. Admins can create directly.
      allow create: if request.auth != null && 
        (request.resource.data.status == 'Pending' || getUserRole() == 'admin' || getUserRole() == 'superadmin'); 
      
      // ✅ Edit or Approve requires Admin/Superadmin. Normal users can ONLY update 'views', 'viewedBy', 'downloads', and 'downloadedBy' fields.
      allow update: if request.auth != null && 
        (
          getUserRole() == 'admin' || 
          getUserRole() == 'superadmin' ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'viewedBy', 'downloads', 'downloadedBy'])
        );
        
      // 🚨 Superadmin only
      allow delete: if request.auth != null && getUserRole() == 'superadmin';
    }

    // 📖 2. SUBJECTS RULES
    match /subjects/{document} {
      allow read: if true; 
      allow write: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'superadmin');
    }

    // 👤 3. USERS COLLECTION RULES
    match /users/{userId} {
      allow read: if true; 
      
      // Normal users can only register themselves with 'student' role and not banned
      allow create: if request.auth != null && request.auth.uid == userId &&
        request.resource.data.role == 'student' &&
        request.resource.data.isBanned == false;
      
      // Prevent normal users from promoting themselves or unbanning themselves
      allow update: if request.auth != null && 
        (
          (request.auth.uid == userId && 
           request.resource.data.role == resource.data.role && 
           request.resource.data.isBanned == resource.data.isBanned) || 
          getUserRole() == 'admin' || 
          getUserRole() == 'superadmin'
        );
        
      allow delete: if request.auth != null && getUserRole() == 'superadmin';
    }

    // 🔔 4. NOTIFICATIONS RULES
    match /notifications/{docId} {
      allow read: if request.auth != null; 
      
      // Normal users can only modify readBy/deletedBy when marking read/unread or deleting
      allow update: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'superadmin' || 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'deletedBy']));
         
      allow create, delete: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'superadmin');
    }

    // 💬 5. FEEDBACKS RULES
    match /feedbacks/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'superadmin');
    }

    // 🔒 6. FALLBACK RULE
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
